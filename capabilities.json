{
  "dataRoles": [
    {
      "displayName": "Set",
      "name": "set",
      "kind": "Grouping",
      "description": "One or more 0/1 columns that define set membership for each pre-aggregated combination.",
      "preferredTypes": [
        {
          "bool": true
        },
        {
          "integer": true
        },
        {
          "numeric": true
        }
      ]
    },
    {
      "displayName": "Count",
      "name": "count",
      "kind": "Measure",
      "description": "The size of the exact combination represented by the row.",
      "requiredTypes": [
        {
          "integer": true
        },
        {
          "numeric": true
        }
      ]
    },
    {
      "displayName": "Label",
      "name": "label",
      "kind": "Grouping",
      "description": "Optional custom label for a combination."
    },
    {
      "displayName": "Sort Metric",
      "name": "sortMetric",
      "kind": "Measure",
      "description": "Optional numeric metric used as a secondary ordering tiebreaker.",
      "preferredTypes": [
        {
          "integer": true
        },
        {
          "numeric": true
        }
      ]
    }
  ],
  "dataViewMappings": [
    {
      "conditions": [
        {
          "set": {
            "max": 20
          },
          "count": {
            "max": 1
          },
          "label": {
            "max": 1
          },
          "sortMetric": {
            "max": 1
          }
        }
      ],
      "matrix": {
        "rows": {
          "select": [
            {
              "for": {
                "in": "set"
              }
            },
            {
              "for": {
                "in": "label"
              }
            }
          ],
          "dataReductionAlgorithm": {
            "top": {
              "count": 30000
            }
          }
        },
        "values": {
          "select": [
            {
              "for": {
                "in": "sortMetric"
              }
            },
            {
              "for": {
                "in": "count"
              }
            }
          ]
        }
      }
    }
  ],
  "objects": {
    "dataDisplay": {
      "properties": {
        "intersectionMode": {
          "type": {
            "enumeration": [
              {
                "value": "exact"
              },
              {
                "value": "inclusive"
              }
            ]
          }
        },
        "maxIntersections": {
          "type": {
            "integer": true
          }
        },
        "sortMode": {
          "type": {
            "enumeration": [
              {
                "value": "countDescending"
              },
              {
                "value": "lexical"
              },
              {
                "value": "degreeThenCount"
              }
            ]
          }
        },
        "minimumCount": {
          "type": {
            "integer": true
          }
        },
        "showOther": {
          "type": {
            "bool": true
          }
        },
        "showEmptyIntersection": {
          "type": {
            "bool": true
          }
        }
      }
    },
    "colors": {
